---
const projects = [
  {
    title: 'Torre Meridian',
    category: 'Edificio Comercial',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1487958449943-2429e8be8625?w=800&q=80',
    large: true,
  },
  {
    title: 'Centro Logístico NorSur',
    category: 'Industrial',
    year: '2023',
    image: 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=600&q=80',
    large: false,
  },
  {
    title: 'Residencial Las Palmas',
    category: 'Residencial',
    year: '2024',
    image: 'https://images.unsplash.com/photo-1580587771525-78b9dba3b914?w=600&q=80',
    large: false,
  },
];
---

<section id="proyectos" class="relative py-24 sm:py-32 overflow-hidden">
  <!-- Background number -->
  <div class="absolute top-12 left-8 text-[15rem] font-syne font-bold text-text-primary/[0.03] leading-none select-none pointer-events-none hidden lg:block">02</div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="flex items-center gap-6 mb-16">
      <div class="w-1 h-16 bg-gradient-to-b from-orange-accent to-transparent rounded-full"></div>
      <div>
        <p class="text-orange-accent text-sm tracking-widest uppercase mb-2 font-medium">Portafolio</p>
        <h2 class="font-syne font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary">
          Proyectos <span class="text-orange-accent">destacados</span>
        </h2>
      </div>
    </div>

    <!-- Projects Grid -->
    <div class="projects-grid grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Large project -->
      <div class="project-card group relative overflow-hidden aspect-[4/5] lg:aspect-auto lg:row-span-2 will-change-transform" style="clip-path: inset(0%);">
        <img
          src={projects[0].image}
          alt={projects[0].title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-transparent opacity-80 group-hover:opacity-60 transition-opacity duration-500"></div>
        <div class="absolute bottom-0 left-0 right-0 p-8">
          <span class="text-cyan-accent text-xs tracking-widest uppercase font-medium">{projects[0].category} &mdash; {projects[0].year}</span>
          <h3 class="font-syne font-bold text-2xl sm:text-3xl text-text-primary mt-2 mb-4">{projects[0].title}</h3>
          <span class="inline-flex items-center gap-2 text-cyan-accent text-sm font-medium opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
            Ver proyecto
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </div>
      </div>

      <!-- Small projects -->
      {projects.slice(1).map((project) => (
        <div class="project-card group relative overflow-hidden aspect-[16/10] will-change-transform" style="clip-path: inset(0%);">
          <img
            src={project.image}
            alt={project.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-primary via-primary/40 to-transparent opacity-80 group-hover:opacity-60 transition-opacity duration-500"></div>
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <span class="text-cyan-accent text-xs tracking-widest uppercase font-medium">{project.category} &mdash; {project.year}</span>
            <h3 class="font-syne font-bold text-xl text-text-primary mt-2 mb-3">{project.title}</h3>
            <span class="inline-flex items-center gap-2 text-cyan-accent text-sm font-medium opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
              Ver proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
