---
const features = [
  {
    num: '01',
    title: 'Modelado 3D BIM',
    desc: 'Creación de modelos 3D paramétricos con información integrada para cada fase del proyecto constructivo.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
  },
  {
    num: '02',
    title: 'Coordinación de clashes',
    desc: 'Detección y resolución de interferencias entre disciplinas antes de la fase de construcción.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
  {
    num: '03',
    title: 'Gestión de proyectos',
    desc: 'Planificación y control integral de proyectos con metodología BIM y cronogramas 4D.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>`,
  },
  {
    num: '04',
    title: 'Renderizado de alta calidad',
    desc: 'Visualizaciones fotorrealistas y recorridos virtuales para presentación de proyectos.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    num: '05',
    title: 'Presupuesto 5D',
    desc: 'Estimación de costos vinculada directamente al modelo BIM con actualizaciones en tiempo real.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
  {
    num: '06',
    title: 'Mantenimiento de activos',
    desc: 'Gestión del ciclo de vida del edificio con modelos as-built y datos operativos integrados.',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
];
---

<section id="servicios" class="relative py-24 sm:py-32 overflow-hidden">
  <!-- Background number -->
  <div class="absolute top-12 right-8 text-[15rem] font-syne font-bold text-text-primary/[0.03] leading-none select-none pointer-events-none hidden lg:block">01</div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="flex items-center gap-6 mb-16">
      <div class="w-1 h-16 bg-gradient-to-b from-cyan-accent to-transparent rounded-full"></div>
      <div>
        <p class="text-cyan-accent text-sm tracking-widest uppercase mb-2 font-medium">Nuestros servicios</p>
        <h2 class="font-syne font-bold text-3xl sm:text-4xl md:text-5xl text-text-primary">
          Soluciones BIM <span class="text-cyan-accent">integrales</span>
        </h2>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="features-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="feature-card group relative bg-surface border-l-2 border-cyan-accent/50 p-8 hover:border hover:border-cyan-accent/40 hover:-translate-y-1 transition-all duration-300 will-change-transform">
          <div class="absolute inset-0 bg-cyan-accent/[0.03] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <span class="absolute top-4 right-6 text-6xl font-syne font-bold text-text-primary/[0.04] select-none pointer-events-none">{feature.num}</span>

          <div class="relative z-10">
            <div class="text-cyan-accent mb-5" set:html={feature.icon} />
            <h3 class="font-syne font-semibold text-lg text-text-primary mb-3">{feature.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{feature.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Decorative line -->
  <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-accent/30 to-transparent"></div>
</section>
