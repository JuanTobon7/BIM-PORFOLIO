---
---

<section class="hero-section relative w-full h-screen min-h-[600px] flex items-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/backgrounds/famous-parasol-structure-sevilla.jpg"
      alt="Edificio moderno"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/90 via-primary/75 to-primary/85"></div>
  </div>

  <!-- Blueprint Grid Effect -->
  <div class="absolute inset-0 blueprint-grid opacity-10"></div>

  <!-- Animated grid lines -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="grid-line-h absolute top-1/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-accent/20 to-transparent"></div>
    <div class="grid-line-h absolute top-2/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-accent/10 to-transparent"></div>
    <div class="grid-line-h absolute top-3/4 left-0 w-full h-px bg-gradient-to-r from-transparent via-cyan-accent/15 to-transparent"></div>
    <div class="grid-line-v absolute top-0 left-1/4 w-px h-full bg-gradient-to-b from-transparent via-cyan-accent/15 to-transparent"></div>
    <div class="grid-line-v absolute top-0 left-2/4 w-px h-full bg-gradient-to-b from-transparent via-cyan-accent/10 to-transparent"></div>
    <div class="grid-line-v absolute top-0 left-3/4 w-px h-full bg-gradient-to-b from-transparent via-cyan-accent/15 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">

      <!-- LEFT COLUMN -->
      <div class="max-w-2xl lg:max-w-lg">

  <!-- Badge -->
  <div class="hero-line inline-flex items-center gap-2 px-4 py-1 border border-border-cyan rounded-full mb-6">
    <span class="w-2 h-2 rounded-full bg-cyan-accent animate-pulse"></span>
    <span class="text-cyan-accent text-xs tracking-widest uppercase font-medium">
      Consultoría BIM
    </span>
  </div>

  <!-- Title -->
  <h1 class="font-syne font-bold leading-[0.95] mb-6 max-w-xl">
    <span class="hero-line block text-5xl sm:text-6xl md:text-6xl lg:text-7xl text-text-primary">
      Transformamos la construcción
    </span>
    <span class="hero-line block text-5xl sm:text-6xl md:text-6xl lg:text-7xl mt-2">
      <span class="text-text-primary">con </span>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-accent to-cyan-400">
        metodología BIM
      </span>
    </span>
  </h1>

  <!-- Subtitle -->
  <p class="hero-line text-text-secondary text-lg max-w-md leading-relaxed mb-8">
    Modelado, coordinación y gestión BIM para proyectos complejos en arquitectura, estructura e instalaciones.
  </p>

</div>

      <!-- RIGHT COLUMN (LOTTIE) -->
      <div class="hero-line hidden lg:flex justify-center items-center right-0">
        <canvas
          id="dotlottie-canvas"
          class="w-full max-w-[800px] h-auto"
        ></canvas>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 hero-line">
    <span class="text-text-secondary text-xs tracking-widest uppercase">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-cyan-accent/50 to-transparent animate-pulse"></div>
  </div>
</section>

<script>
  import { DotLottie } from '@lottiefiles/dotlottie-web';

  // Initialize dotLottie animation when DOM is ready
  const canvas = document.querySelector('#dotlottie-canvas');
  if (canvas) {
    const dotLottie = new DotLottie({
      canvas: canvas,
      autoplay: false,
      loop: true,
      src: '/animations/Construction_works.json',
      renderConfig: {
        autoResize: true,
        devicePixelRatio: 1,
      },
      layout: {
        fit: 'cover',
        align: [0.5, 0.5],
      },
      speed: 1,
    });

    // Store in window for GSAP to access
    window.dotLottieInstance = dotLottie;
  }
</script>

<style>
  .blueprint-grid {
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.06) 1px, transparent 1px);
    background-size: 60px 60px;
  }
</style>
